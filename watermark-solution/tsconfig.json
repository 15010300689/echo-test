{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types"
  },
  "include": [
    "core/**/*.ts",
    "adapters/**/*.ts",
    "adapters/**/*.tsx",
    "index.ts"
  ],
  "exclude": [
    "examples/**",
    "dist/**",
    "node_modules/**"
  ]
}
