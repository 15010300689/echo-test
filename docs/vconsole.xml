<?xml version='1.0' encoding='UTF-8' ?>
<?charles serialisation-version='2.0' ?>
<rewriteSet-array>
  <rewriteSet>
    <active>true</active>
    <name>添加vconsole-style</name>
    <hosts>
      <locationPatterns>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>mfangxin.58.com</host>
            <path>/m/v1/*.html</path>
          </location>
          <enabled>true</enabled>
        </locationMatch>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>127.0.0.1</host>
            <port>4000</port>
            <path>/m/v1/*.html</path>
          </location>
          <enabled>true</enabled>
        </locationMatch>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>127.0.0.1</host>
            <port>8080</port>
            <path>/*.html</path>
          </location>
          <enabled>true</enabled>
        </locationMatch>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>unionhy.58.com</host>
            <path>*</path>
            <query>*</query>
          </location>
          <enabled>false</enabled>
        </locationMatch>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>auntapp.58.com</host>
            <path>/*.html</path>
            <query>*</query>
          </location>
          <enabled>true</enabled>
        </locationMatch>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>aunt.58.com</host>
            <path>/html/auntIncomeDesc.html</path>
            <query>orderId=3459678588088419266</query>
          </location>
          <enabled>false</enabled>
        </locationMatch>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>cscauth.58.com</host>
            <path>/training/h5/*</path>
            <query>*</query>
          </location>
          <enabled>true</enabled>
        </locationMatch>
      </locationPatterns>
    </hosts>
    <rules>
      <rewriteRule>
        <active>true</active>
        <ruleType>7</ruleType>
        <matchValue>&lt;/head&gt;</matchValue>
        <matchHeaderRegex>false</matchHeaderRegex>
        <matchValueRegex>false</matchValueRegex>
        <matchRequest>false</matchRequest>
        <matchResponse>true</matchResponse>
        <newValue>&lt;script src=&quot;//cdn.bootcdn.net/ajax/libs/vConsole/3.3.4/vconsole.min.js&quot;&gt;&lt;/script&gt;&lt;style&gt;#__vconsole .vc-switch {bottom: 100px!important;}&lt;/style&gt;&lt;/head&gt;</newValue>
        <newHeaderRegex>false</newHeaderRegex>
        <newValueRegex>false</newValueRegex>
        <matchWholeValue>false</matchWholeValue>
        <caseSensitive>false</caseSensitive>
        <replaceType>1</replaceType>
      </rewriteRule>
      <rewriteRule>
        <active>true</active>
        <ruleType>7</ruleType>
        <matchValue>&lt;/body&gt;</matchValue>
        <matchHeaderRegex>false</matchHeaderRegex>
        <matchValueRegex>false</matchValueRegex>
        <matchRequest>false</matchRequest>
        <matchResponse>true</matchResponse>
        <newValue>&lt;script&gt;window.VConsole &amp;&amp; new window.VConsole();&lt;/script&gt;&lt;/body&gt;</newValue>
        <newHeaderRegex>false</newHeaderRegex>
        <newValueRegex>false</newValueRegex>
        <matchWholeValue>false</matchWholeValue>
        <caseSensitive>false</caseSensitive>
        <replaceType>1</replaceType>
      </rewriteRule>
    </rules>
  </rewriteSet>
</rewriteSet-array>